mainmenu "tinyso3"

choice
     prompt "Default floating point precision"
     default DEFAULT_FLOATING_POINT_PRECISION_32
     config DEFAULT_FLOATING_POINT_PRECISION_32
          bool "float(32)"
     config DEFAULT_FLOATING_POINT_PRECISION_64
          bool "double(64)"
     config DEFAULT_FLOATING_POINT_PRECISION_128
          bool "long double(128)"
endchoice

choice 
     prompt "Default rotation matrix transformation convention"
     default DEFAULT_ROTATION_MATRIX_TRANSFORMATION_CONVENTION_ACTIVE
     config DEFAULT_ROTATION_MATRIX_TRANSFORMATION_CONVENTION_ACTIVE
          bool "Active(Alibi)"
     config DEFAULT_ROTATION_MATRIX_TRANSFORMATION_CONVENTION_PASSIVE
          bool "Passive(Alias)"
endchoice